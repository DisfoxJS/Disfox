{
  "compilerOptions": {
    "target": "ES2020",               
    "module": "Node16",
    "moduleResolution": "Node16",
    "rootDir": "src",
    "outDir": "dist",

    "declaration": true,
    "declarationMap": true,

    "emitDeclarationOnly": false,
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true, 
    "skipLibCheck": true                    
  },
  "include": ["src/**/*"],  
  "exclude": ["node_modules", "dist", "assets"]
}